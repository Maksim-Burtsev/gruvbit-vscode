  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#968772"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template", "punctuation.definition.string"],
      "settings": {
        "foreground": "#8ec07c"
      }
    },
    {
      "name": "Statement — keywords and storage",
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#fabd2f"
      }
    },
    {
      "name": "Operators — foreground, not colored",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#ebdbb2"
      }
    },
    {
      "name": "PreProc — import/from/export",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#dc9656"
      }
    },
    {
      "name": "PreProc — decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#dc9656"
      }
    },
    {
      "name": "PreProc — preprocessor directives",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#dc9656"
      }
    },
    {
      "name": "Constant — language constants and numbers",
      "scope": ["constant.language", "constant.numeric"],
      "settings": {
        "foreground": "#d3869b"
      }
    },
    {
      "name": "Special — escape sequences",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#e9593d"
      }
    },
    {
      "name": "Identifier — function definition name only",
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "name": "Type — type and class names",
      "scope": ["entity.name.type", "entity.name.class", "support.type"],
      "settings": {
        "foreground": "#fabd2f"
      }
    },
    {
      "name": "Tag — HTML/XML/JSX tag names",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#dc9656"
      }
    },
    {
      "name": "Title — headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#fabd2f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup — bold",
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup — italic",
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup — underline",
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup — inline code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#dc9656"
      }
    },
    {
      "name": "Markup — inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#8ec07c"
      }
    },
    {
      "name": "Markup — deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#e9593d"
      }
    },
    {
      "name": "Markup — changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "name": "Markup — link",
      "scope": ["string.other.link", "markup.underline.link"],
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "name": "Markup — quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#968772"
      }
    },
    {
      "name": "Markup — list marker",
      "scope": "markup.list",
      "settings": {
        "foreground": "#dc9656"
      }
    }
  ]
}
